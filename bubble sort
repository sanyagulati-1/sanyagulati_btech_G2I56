
#include <stdio.h>

int main() {
    int n,temp,a[100];
    printf("enter number of elements \n");
    scanf("%d",&n);
    printf("enter %d integers \n",n);
    for(int i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    for(int i=0;i<n;i++)
    {
        for(int j=0;j<n-1;j++)
        {
            if(a[j]>a[j+1])
            {
            temp=a[j];
            a[j]=a[j+1];
            a[j+1]=temp;
            }
        }
    }
    printf("sorted list in ascending order \n");
    for(int i=0;i<n;i++)
    {
        printf("%d \n",a[i]);
    }
    return 0;
}
    
